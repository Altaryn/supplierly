# ============================================================================
# Supplierly — variables de entorno. Copia este archivo a .env.local y completa
# los valores. NUNCA subas .env.local al repositorio (ya está en .gitignore).
#
# Sin estas variables la app arranca en MODO DEMO: los proveedores se leen de
# datos de ejemplo en memoria y las escrituras no se persisten. Configúralas
# para conectar tu proyecto Supabase real.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor. NUNCA usar en el cliente. Lo usan las Server Actions para
# escribir en la base y subir archivos a Storage saltándose RLS de forma segura.
SUPABASE_SERVICE_ROLE_KEY=

# Nombre del bucket de Storage para la documentación de proveedores.
# Debe coincidir con el creado en supabase/schema.sql (por defecto: supplier-docs).
SUPABASE_STORAGE_BUCKET=supplier-docs

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
